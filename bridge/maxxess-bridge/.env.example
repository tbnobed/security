# Where to push (your FrontDesk server, reachable from this machine)
FRONTDESK_URL=https://sec.example.com

# Shared secret — must exactly match MAXXESS_BRIDGE_TOKEN on the FrontDesk api
# service. Generate one with: openssl rand -hex 32
BRIDGE_TOKEN=

# How often to read Maxxess and push (seconds, default 60)
POLL_INTERVAL_SECONDS=60

# Data source: "mock" (built-in test data, no Maxxess needed) or "efusion"
# (edit readEfusion() in index.mjs for your eFusion API module first)
SOURCE=mock

# Only needed for SOURCE=efusion:
EFUSION_BASE_URL=
EFUSION_USERNAME=
EFUSION_PASSWORD=
