# Where to push (your FrontDesk server, reachable from this machine)
FRONTDESK_URL=https://sec.example.com

# Shared secret — must exactly match MAXXESS_BRIDGE_TOKEN on the FrontDesk api
# service. Generate one with: openssl rand -hex 32
BRIDGE_TOKEN=

# How often to read Maxxess and push (seconds, default 60)
POLL_INTERVAL_SECONDS=60

# Data source:
#   mock        = built-in test data, no Maxxess needed (verify connectivity first)
#   efusion-sql = read the eFusion SQL Server database directly (see SQL-SETUP.md;
#                 requires `npm install` in this folder for the mssql driver)
#   efusion     = eFusion Web API template (separately licensed Maxxess module)
SOURCE=mock

# --- SOURCE=efusion-sql settings (see SQL-SETUP.md) ---
EFUSION_SQL_SERVER=CONTEGO3
# Prefer a fixed TCP port (pinned in SQL Server Configuration Manager):
EFUSION_SQL_PORT=1433
# ...or comment out EFUSION_SQL_PORT and use the named instance instead
# (requires the SQL Browser service + UDP 1434 reachable):
#EFUSION_SQL_INSTANCE=MAXXESS
EFUSION_SQL_DATABASE=AXxess
EFUSION_SQL_USER=frontdesk_reader
EFUSION_SQL_PASSWORD=
# Set to "true" only if the SQL Server has TLS configured:
EFUSION_SQL_ENCRYPT=false
# eFusion datetimes are local wall time; run the bridge in the same timezone
# as the SQL Server machine. Set "true" only if your DB stores UTC:
EFUSION_SQL_USE_UTC=false

# Only needed for SOURCE=efusion (Web API):
EFUSION_BASE_URL=
EFUSION_USERNAME=
EFUSION_PASSWORD=
