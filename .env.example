# ---------------------------------------------------------------------------
# FrontDesk — Docker deployment configuration
# Copy this file to `.env` (same directory as docker-compose.yml) and edit.
#   cp .env.example .env
# docker compose reads `.env` automatically.
# ---------------------------------------------------------------------------

# --- Database (Postgres runs as the `db` service) ---
POSTGRES_USER=frontdesk
POSTGRES_DB=frontdesk
# REQUIRED — pick a strong password. This value is placed into a Postgres
# connection URL, so use only URL-safe characters (letters, digits, and
# - _ . ~). Avoid @ : / # % ? & or spaces, which would corrupt the URL.
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Sessions (REQUIRED) ---
# Long random string used to sign session cookies. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=change-me-run-openssl-rand-hex-32

# Set to "true" ONLY when the app is served over HTTPS (e.g. behind a TLS
# reverse proxy). Leave "false" for plain HTTP on a LAN/IP, otherwise login
# will silently fail because the browser won't send a Secure cookie over HTTP.
SESSION_COOKIE_SECURE=false

# --- Initial admin account (seeded on first `docker compose up`) ---
# SEED_ADMIN_PASSWORD is REQUIRED (compose refuses to start without it) so an
# install can never ship with a known default password. Pick a strong one.
SEED_ADMIN_EMAIL=admin@studiogms.com
SEED_ADMIN_PASSWORD=change-me-strong-admin-password

# --- Host port the app is published on ---
HTTP_PORT=80

# --- Frontend branding (baked in at build time; rebuild `web` after changing) ---
# Single static site/location name shown across the app.
VITE_SITE_NAME=Dallas/The Plex
# Client branding for the PUBLIC /preregister page (optional).
#   VITE_CLIENT_NAME — label under the logo (blank = use VITE_SITE_NAME)
#   VITE_CLIENT_LOGO — a filename already in artifacts/studio-gms/public/
#                      (e.g. client-logo.png) or a full URL. Blank = default mark.
VITE_CLIENT_NAME=TBN
VITE_CLIENT_LOGO=client-logo.png
# Privacy notice page (/privacy) configuration (optional).
#   VITE_PRIVACY_CONTACT   — who visitors contact for privacy/data requests, e.g.
#                            privacy@example.com (blank = "the security desk")
#   VITE_PRIVACY_RETENTION — retention statement shown on the privacy page, e.g.
#                            "Visitor records are retained for 24 months." (blank = generic wording)
VITE_PRIVACY_CONTACT=
VITE_PRIVACY_RETENTION=
# Printed visitor-badge size — DEFAULT label size only. Each security desk sets
# its own size in-app (the "Label size" control by the Print Badge button),
# saved per-browser, since different desks can have different printers. These
# just seed the default. CSS length in in/mm/cm (e.g. 2.4in, 62mm). Default 3in x 2in.
VITE_BADGE_WIDTH=3in
VITE_BADGE_HEIGHT=2in

# --- Timezone (optional; defaults to UTC) ---
# IANA timezone name used by the API server for timestamps in alert/approval
# emails and for "today" windows (kiosk expected-guest search, Productions
# Today, client portal Today's Visits). Examples:
#   America/Chicago  America/New_York  America/Los_Angeles
# The web UI always shows times in each viewer's own browser timezone;
# this setting only affects server-generated times.
TZ=America/Chicago

# --- Email alerts (optional; leave blank to disable) ---
# Requires BOTH values. The from-address must be a Verified Sender / domain
# in your SendGrid account or SendGrid will reject the send.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# --- Pre-registration approval emails (optional) ---
# Public base URL of the app as approvers reach it in a browser, e.g.
#   http://192.168.1.10  or  https://frontdesk.example.com
# Used to build the one-click Approve/Deny links in approver emails.
# Recommended: set it explicitly in production. If left blank, the server
# falls back to the URL it learns from security/admin staff sign-ins; until
# a staff member has signed in once, approval emails omit the buttons and
# direct approvers to the in-app Approvals page.
APP_BASE_URL=

# --- External bookings API for the "Productions Today" panel (optional) ---
# Defaults to the public Plex bookings API if left unset.
BOOKINGS_API_URL=https://plex.bookstud.io/api/public/bookings

# --- Maxxess access-control bridge (optional; leave blank to disable) ---
# Shared secret the LAN bridge (bridge/maxxess-bridge/) uses to push building
# occupancy + door events into FrontDesk. Generate with: openssl rand -hex 32
# and set the SAME value as BRIDGE_TOKEN in the bridge's .env.
MAXXESS_BRIDGE_TOKEN=
