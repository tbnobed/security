# Static site (campus/building) name for this deployment.
# Change this per install; the app stamps every visit with this value.
VITE_SITE_NAME="Studio"

# Client branding for the PUBLIC visitor pre-registration page (/preregister).
# Update these per client, then restart the web workflow (Vite embeds env at build time).
#   VITE_CLIENT_NAME — name shown under the client logo (blank = use VITE_SITE_NAME)
#   VITE_CLIENT_LOGO — logo filename in public/ (e.g. "client-logo.png") or a full URL.
#                      Blank = fall back to the default FrontDesk mark.
VITE_CLIENT_NAME=""
VITE_CLIENT_LOGO=""
